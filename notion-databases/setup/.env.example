# Copy this to .env and fill in values
# NEVER commit .env to git

NOTION_TOKEN=ntn_your_token_here
# Rotate your token at notion.so/profile/integrations after initial setup

# n8n (used in workflow JSON files for reference)
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.n8n.cloud/webhook

# External services (optional — used in n8n workflows)
AIRTOP_API_KEY=your_airtop_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_secret_here
