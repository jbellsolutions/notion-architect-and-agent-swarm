# Notion Agent Orchestrator — environment variables
# Copy to .env.local for local dev, or set in Railway dashboard for production.
# See SETUP.md for where each value comes from.

# === Notion data layer (notion-databases/setup/create_missing_dbs.py) ===
NOTION_TOKEN=ntn_your_internal_integration_token
PARENT_PAGE_ID=00000000000000000000000000000000

# === Anthropic Managed Agent ===
ANTHROPIC_API_KEY=sk-ant-api03-xxx
ANTHROPIC_AGENT_ID=agent_xxx              # from `curl POST /v1/agents`
ANTHROPIC_ENVIRONMENT_ID=env_xxx          # from `curl POST /v1/environments`
ANTHROPIC_VAULT_IDS=vlt_xxx               # comma-separated if multiple

# === Composio Tool Router (MCP server) ===
# These are NOT used directly by the web app — they're stored inside the Anthropic vault as a credential.
# Listed here only for reference / re-provisioning.
COMPOSIO_MCP_URL=https://backend.composio.dev/tool_router/trs_xxx/mcp
COMPOSIO_MCP_TOKEN=sphxxxxxxxxxxxxxxxx

# === OpenAI (Whisper voice transcription only) ===
OPENAI_API_KEY=sk-proj-xxx

# === App auth (Justin + co. only) ===
APP_PASSWORD=change-me-now
APP_SESSION_SECRET=run_openssl_rand_hex_32

# === Slack bridge (Phase 6) ===
SLACK_BOT_TOKEN=xoxb-xxx-xxx-xxx          # from Slack app → OAuth & Permissions → Bot User OAuth Token
SLACK_SIGNING_SECRET=32_char_hex_from_slack_basic_information

# === Optional: n8n workflows (Phase 1) ===
# Each n8n workflow imports its own credentials. Configure inside n8n, not here.
