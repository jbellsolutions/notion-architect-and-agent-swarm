# ──────────────────────────────────────────────────────────────────
# Required: Anthropic Managed Agent
# ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_AGENT_ID=agt_...
ANTHROPIC_ENVIRONMENT_ID=env_...

# Optional: Anthropic Vault IDs for MCP credentials (comma-separated)
ANTHROPIC_VAULT_IDS=vlt_...

# ──────────────────────────────────────────────────────────────────
# Required: OpenAI (Whisper transcription only)
# ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────────────────────────
# Required: App auth (web dashboard)
# ──────────────────────────────────────────────────────────────────
APP_PASSWORD=change-me
APP_SESSION_SECRET=generate-with-openssl-rand-hex-32

# ──────────────────────────────────────────────────────────────────
# Required for Slack bridge
# ──────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# ──────────────────────────────────────────────────────────────────
# Reliability layer (Wave 2) — optional but strongly recommended.
# Without DATABASE_URL the app degrades gracefully to in-memory session
# state and no telemetry. Provision Railway Postgres to enable.
# ──────────────────────────────────────────────────────────────────
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Synthetic supervisor — POST /api/cron/healthcheck with this header
# generate with: openssl rand -hex 32
CRON_SECRET=

# Slack alerting — channel ID + your user ID (for DMs)
ALERTS_SLACK_CHANNEL=C0XXXXXXXXX
JUSTIN_SLACK_USER_ID=U0XXXXXXXXX

# Railway webhook receiver — for build-failure alerts
# generate with: openssl rand -hex 24
RAILWAY_WEBHOOK_SECRET=
